# LLM (analyze + plan). Leave unset to force MOTN_LLM=mock.
ANTHROPIC_API_KEY=

# Transcription vendors
ELEVENLABS_API_KEY=
GROQ_API_KEY=

# Stage backends: which implementation each AI stage uses.
#   MOTN_STT:  scribe | groq | mock   (default: scribe if key set, else groq if key set, else mock)
#   MOTN_LLM:  anthropic | mock       (default: anthropic if key set, else mock)
MOTN_STT=
MOTN_LLM=

# Anthropic model for analyze/plan passes
MOTN_MODEL=claude-opus-4-8

# Chromium binary for @remotion/renderer. If unset, Remotion downloads its own
# headless shell. In this dev container: /opt/pw-browsers/chromium_headless_shell-1194/...
MOTN_BROWSER_EXECUTABLE=
